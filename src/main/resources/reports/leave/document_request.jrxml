<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="document_request" pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">

    <parameter name="companyName"        class="java.lang.String"/>
    <parameter name="referenceNumber"    class="java.lang.String"/>
    <parameter name="employeeFullName"   class="java.lang.String"/>
    <parameter name="employeeEmail"      class="java.lang.String"/>
    <parameter name="employeeDepartment" class="java.lang.String"/>
    <parameter name="documentType"       class="java.lang.String"/>
    <parameter name="notes"              class="java.lang.String"/>
    <parameter name="requestedAt"        class="java.lang.String"/>
    <parameter name="processedAt"        class="java.lang.String"/>
    <parameter name="hrNote"             class="java.lang.String"/>
    <parameter name="logoStream"         class="java.io.InputStream"/>
    <parameter name="balanceYear"        class="java.lang.String"/>
    <parameter name="balanceLeaveType"   class="java.lang.String"/>
    <parameter name="allocatedDays"      class="java.lang.String"/>
    <parameter name="carryForwardDays"   class="java.lang.String"/>
    <parameter name="usedDays"           class="java.lang.String"/>
    <parameter name="reservedDays"       class="java.lang.String"/>
    <parameter name="availableDays"      class="java.lang.String"/>
    <parameter name="generatedOn"        class="java.lang.String"/>

    <background><band splitType="Stretch"/></background>

    <title>
        <band height="115" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="75" backcolor="#0F172A" forecolor="#0F172A"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="0" y="75" width="535" height="4" backcolor="#2563EB" forecolor="#2563EB"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <image scaleImage="RetainShape">
                <reportElement x="12" y="10" width="50" height="50"/>
                <imageExpression><![CDATA[$P{logoStream}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="72" y="10" width="300" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="15" isBold="true" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{companyName}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="72" y="36" width="300" height="16" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="10" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[Leave Balance Statement]]></text>
            </staticText>
            <staticText>
                <reportElement x="72" y="52" width="300" height="14" forecolor="#93C5FD"/>
                <textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement>
                <text><![CDATA[Official Employee Leave Balance Document]]></text>
            </staticText>
            <staticText>
                <reportElement x="370" y="10" width="165" height="13" forecolor="#94A3B8"/>
                <textElement textAlignment="Right"><font size="7" fontName="SansSerif"/></textElement>
                <text><![CDATA[REFERENCE NO.]]></text>
            </staticText>
            <textField>
                <reportElement x="370" y="24" width="165" height="18" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right"><font size="12" isBold="true" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{referenceNumber}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="370" y="46" width="165" height="14" forecolor="#64748B"/>
                <textElement textAlignment="Right"><font size="7" fontName="SansSerif"/></textElement>
                <text><![CDATA[Official HR Document]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="85" width="80" height="18" forecolor="#64748B"/>
                <textElement verticalAlignment="Middle"><font size="7" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[DATE ISSUED]]></text>
            </staticText>
            <textField>
                <reportElement x="82" y="85" width="200" height="18" forecolor="#1E293B"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{processedAt}]]></textFieldExpression>
            </textField>
            <rectangle>
                <reportElement x="400" y="82" width="135" height="24" backcolor="#EDE9FE" forecolor="#EDE9FE"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="400" y="82" width="135" height="24" forecolor="#5B21B6"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="11" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[APPROVED]]></text>
            </staticText>
        </band>
    </title>

    <detail>
        <!-- EMPLOYEE INFO -->
        <band height="120" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="12" width="535" height="20" backcolor="#3B0764" forecolor="#3B0764"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="12" width="400" height="20" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[EMPLOYEE INFORMATION]]></text>
            </staticText>
            <staticText><reportElement x="0" y="40" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Full Name]]></text></staticText>
            <textField><reportElement x="180" y="40" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="9" isBold="true" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{employeeFullName}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="57" width="535" height="1" forecolor="#E2E8F0"/></line>
            <staticText><reportElement x="0" y="62" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Department]]></text></staticText>
            <textField isBlankWhenNull="true"><reportElement x="180" y="62" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{employeeDepartment} != null && !$P{employeeDepartment}.isEmpty() ? $P{employeeDepartment} : "—"]]></textFieldExpression></textField>
            <line><reportElement x="0" y="79" width="535" height="1" forecolor="#E2E8F0"/></line>
            <staticText><reportElement x="0" y="84" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Email Address]]></text></staticText>
            <textField><reportElement x="180" y="84" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{employeeEmail}]]></textFieldExpression></textField>
        </band>

        <!-- DOCUMENT DETAILS -->
        <band height="120" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="12" width="535" height="20" backcolor="#1E3A5F" forecolor="#1E3A5F"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="12" width="400" height="20" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[STATEMENT INFORMATION]]></text>
            </staticText>
            <staticText><reportElement x="0" y="40" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Document Type]]></text></staticText>
            <textField><reportElement x="180" y="40" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="9" isBold="true" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{documentType}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="57" width="535" height="1" forecolor="#E2E8F0"/></line>
            <staticText><reportElement x="0" y="62" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Request Submitted]]></text></staticText>
            <textField><reportElement x="180" y="62" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{requestedAt}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="79" width="535" height="1" forecolor="#E2E8F0"/></line>
            <staticText><reportElement x="0" y="84" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Purpose / Notes]]></text></staticText>
            <textField isStretchWithOverflow="true" isBlankWhenNull="true"><reportElement x="180" y="84" width="355" height="30" forecolor="#0F172A"/><textElement verticalAlignment="Top"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{notes} != null && !$P{notes}.isEmpty() ? $P{notes} : "—"]]></textFieldExpression></textField>
        </band>

        <!-- LEAVE BALANCE SUMMARY -->
        <band height="128" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="12" width="535" height="20" backcolor="#1E3A5F" forecolor="#1E3A5F"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="12" width="400" height="20" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[LEAVE BALANCE SUMMARY]]></text>
            </staticText>

            <!-- Row 1 -->
            <staticText><reportElement x="0" y="40" width="130" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Balance Year]]></text></staticText>
            <textField><reportElement x="135" y="40" width="130" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{balanceYear}]]></textFieldExpression></textField>
            <staticText><reportElement x="275" y="40" width="120" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Leave Type]]></text></staticText>
            <textField><reportElement x="400" y="40" width="135" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{balanceLeaveType}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="57" width="535" height="1" forecolor="#E2E8F0"/></line>

            <!-- Row 2 -->
            <staticText><reportElement x="0" y="62" width="130" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Allocated Days]]></text></staticText>
            <textField><reportElement x="135" y="62" width="130" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{allocatedDays}]]></textFieldExpression></textField>
            <staticText><reportElement x="275" y="62" width="120" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Carry-forward Days]]></text></staticText>
            <textField><reportElement x="400" y="62" width="135" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{carryForwardDays}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="79" width="535" height="1" forecolor="#E2E8F0"/></line>

            <!-- Row 3 -->
            <staticText><reportElement x="0" y="84" width="130" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Used Days]]></text></staticText>
            <textField><reportElement x="135" y="84" width="130" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{usedDays}]]></textFieldExpression></textField>
            <staticText><reportElement x="275" y="84" width="120" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Reserved Days]]></text></staticText>
            <textField><reportElement x="400" y="84" width="135" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{reservedDays}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="101" width="535" height="1" forecolor="#E2E8F0"/></line>

            <!-- Row 4 -->
            <staticText><reportElement x="0" y="106" width="130" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Available Days]]></text></staticText>
            <textField><reportElement x="135" y="106" width="130" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="9" isBold="true" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{availableDays}]]></textFieldExpression></textField>
            <staticText><reportElement x="275" y="106" width="120" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Generated On]]></text></staticText>
            <textField><reportElement x="400" y="106" width="135" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{generatedOn}]]></textFieldExpression></textField>
        </band>

        <!-- HR NOTE -->
        <band height="80" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="12" width="535" height="20" backcolor="#1E3A5F" forecolor="#1E3A5F"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="12" width="400" height="20" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[HR NOTE]]></text>
            </staticText>
            <rectangle>
                <reportElement x="0" y="40" width="535" height="34" backcolor="#F8FAFC" forecolor="#E2E8F0"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </rectangle>
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement x="10" y="43" width="515" height="28" forecolor="#1E3A5F"/>
                <textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{hrNote} != null && !$P{hrNote}.isEmpty() ? $P{hrNote} : "This leave balance statement has been approved and generated by the Human Resources department."]]></textFieldExpression>
            </textField>
        </band>

        <!-- FOOTER -->
        <band height="92" splitType="Stretch">
            <line>
                <reportElement x="0" y="10" width="535" height="1" forecolor="#CBD5E1"/>
            </line>
            <staticText>
                <reportElement x="0" y="18" width="535" height="20" forecolor="#475569"/>
                <textElement verticalAlignment="Middle">
                    <font size="7" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[This statement is generated by the ArabSoft Human Resources Management System based on the approved employee document request. For administrative verification, quote the reference number shown above.]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="48" width="535" height="1" forecolor="#0F172A"/>
            </line>
            <textField>
                <reportElement x="0" y="54" width="267" height="10" forecolor="#64748B"/>
                <textElement verticalAlignment="Middle"><font size="6" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{companyName} + " · Human Resources Management System"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="268" y="54" width="267" height="10" forecolor="#64748B"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="6" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA["Ref: " + $P{referenceNumber} + "  ·  Page 1 of 1"]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
