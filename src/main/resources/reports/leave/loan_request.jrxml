<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="loan_request" pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">

    <parameter name="companyName"        class="java.lang.String"/>
    <parameter name="referenceNumber"    class="java.lang.String"/>
    <parameter name="employeeFullName"   class="java.lang.String"/>
    <parameter name="employeeEmail"      class="java.lang.String"/>
    <parameter name="employeeDepartment" class="java.lang.String"/>
    <parameter name="loanType"           class="java.lang.String"/>
    <parameter name="amount"             class="java.lang.String"/>
    <parameter name="repaymentMonths"    class="java.lang.String"/>
    <parameter name="reason"             class="java.lang.String"/>
    <parameter name="requestedAt"        class="java.lang.String"/>
    <parameter name="processedAt"        class="java.lang.String"/>
    <parameter name="hrNote"             class="java.lang.String"/>
    <parameter name="logoStream"         class="java.io.InputStream"/>
    <parameter name="qrCodeStream"       class="java.io.InputStream"/>

    <background><band splitType="Stretch"/></background>

    <title>
        <band height="115" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="75" backcolor="#0F172A" forecolor="#0F172A"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="0" y="75" width="535" height="4" backcolor="#0284C7" forecolor="#0284C7"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <image scaleImage="RetainShape">
                <reportElement x="12" y="10" width="50" height="50"/>
                <imageExpression><![CDATA[$P{logoStream}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="72" y="10" width="300" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="15" isBold="true" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{companyName}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="72" y="38" width="300" height="18" forecolor="#BAE6FD"/>
                <textElement verticalAlignment="Middle"><font size="9" fontName="SansSerif"/></textElement>
                <text><![CDATA[Loan & Advance Authorization Certificate]]></text>
            </staticText>
            <staticText>
                <reportElement x="370" y="10" width="165" height="13" forecolor="#94A3B8"/>
                <textElement textAlignment="Right"><font size="7" fontName="SansSerif"/></textElement>
                <text><![CDATA[REFERENCE NO.]]></text>
            </staticText>
            <textField>
                <reportElement x="370" y="24" width="165" height="18" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right"><font size="12" isBold="true" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{referenceNumber}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="370" y="46" width="165" height="14" forecolor="#64748B"/>
                <textElement textAlignment="Right"><font size="7" fontName="SansSerif"/></textElement>
                <text><![CDATA[Confidential — HR Use Only]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="85" width="80" height="18" forecolor="#64748B"/>
                <textElement verticalAlignment="Middle"><font size="7" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[DATE ISSUED]]></text>
            </staticText>
            <textField>
                <reportElement x="82" y="85" width="200" height="18" forecolor="#1E293B"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{processedAt}]]></textFieldExpression>
            </textField>
            <rectangle>
                <reportElement x="400" y="82" width="135" height="24" backcolor="#DCFCE7" forecolor="#DCFCE7"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="400" y="82" width="135" height="24" forecolor="#15803D"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="11" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[✓  APPROVED]]></text>
            </staticText>
        </band>
    </title>

    <detail>
        <!-- EMPLOYEE INFO -->
        <band height="120" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="12" width="535" height="20" backcolor="#0C4A6E" forecolor="#0C4A6E"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="12" width="400" height="20" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[EMPLOYEE INFORMATION]]></text>
            </staticText>
            <staticText><reportElement x="0" y="40" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Full Name]]></text></staticText>
            <textField><reportElement x="180" y="40" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="9" isBold="true" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{employeeFullName}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="57" width="535" height="1" forecolor="#E2E8F0"/></line>
            <staticText><reportElement x="0" y="62" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Department]]></text></staticText>
            <textField isBlankWhenNull="true"><reportElement x="180" y="62" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{employeeDepartment} != null && !$P{employeeDepartment}.isEmpty() ? $P{employeeDepartment} : "—"]]></textFieldExpression></textField>
            <line><reportElement x="0" y="79" width="535" height="1" forecolor="#E2E8F0"/></line>
            <staticText><reportElement x="0" y="84" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Email Address]]></text></staticText>
            <textField><reportElement x="180" y="84" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{employeeEmail}]]></textFieldExpression></textField>
        </band>

        <!-- LOAN DETAILS -->
        <band height="165" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="12" width="535" height="20" backcolor="#0C4A6E" forecolor="#0C4A6E"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="12" width="400" height="20" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[LOAN DETAILS]]></text>
            </staticText>
            <staticText><reportElement x="0" y="40" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Loan Type]]></text></staticText>
            <textField><reportElement x="180" y="40" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="9" isBold="true" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{loanType}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="57" width="535" height="1" forecolor="#E2E8F0"/></line>

            <!-- Amount highlighted -->
            <staticText><reportElement x="0" y="62" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Approved Amount]]></text></staticText>
            <rectangle>
                <reportElement x="178" y="61" width="150" height="20" backcolor="#DBEAFE" forecolor="#DBEAFE"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <textField>
                <reportElement x="180" y="62" width="150" height="18" forecolor="#1D4ED8"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font size="11" isBold="true" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{amount}]]></textFieldExpression>
            </textField>
            <line><reportElement x="0" y="83" width="535" height="1" forecolor="#E2E8F0"/></line>

            <staticText><reportElement x="0" y="88" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Repayment Period]]></text></staticText>
            <textField><reportElement x="180" y="88" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{repaymentMonths} + " months"]]></textFieldExpression></textField>
            <line><reportElement x="0" y="105" width="535" height="1" forecolor="#E2E8F0"/></line>

            <staticText><reportElement x="0" y="110" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Request Submitted]]></text></staticText>
            <textField><reportElement x="180" y="110" width="355" height="16" forecolor="#0F172A"/><textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{requestedAt}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="127" width="535" height="1" forecolor="#E2E8F0"/></line>

            <staticText><reportElement x="0" y="132" width="175" height="16" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement><text><![CDATA[Reason]]></text></staticText>
            <textField isStretchWithOverflow="true"><reportElement x="180" y="132" width="355" height="28" forecolor="#0F172A"/><textElement verticalAlignment="Top"><font size="8" fontName="SansSerif"/></textElement><textFieldExpression><![CDATA[$P{reason}]]></textFieldExpression></textField>
        </band>

        <!-- HR NOTE -->
        <band height="80" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="12" width="535" height="20" backcolor="#0C4A6E" forecolor="#0C4A6E"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="12" width="400" height="20" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[HR AUTHORIZATION NOTE]]></text>
            </staticText>
            <rectangle>
                <reportElement x="0" y="40" width="535" height="34" backcolor="#EFF6FF" forecolor="#BFDBFE"/>
                <graphicElement><pen lineWidth="0.5"/></graphicElement>
            </rectangle>
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement x="10" y="43" width="515" height="28" forecolor="#1E3A5F"/>
                <textElement verticalAlignment="Middle"><font size="8" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{hrNote} != null && !$P{hrNote}.isEmpty() ? $P{hrNote} : "Loan approved. Amount will be disbursed via payroll within the agreed schedule."]]></textFieldExpression>
            </textField>
        </band>

        <!-- FOOTER -->
        <band height="130" splitType="Stretch">
            <line><reportElement x="0" y="12" width="535" height="1" forecolor="#CBD5E1"/></line>
            <image scaleImage="RetainShape" isUsingCache="false">
                <reportElement x="0" y="20" width="90" height="90">
                    <printWhenExpression><![CDATA[$P{qrCodeStream} != null]]></printWhenExpression>
                </reportElement>
                <imageExpression><![CDATA[$P{qrCodeStream}]]></imageExpression>
            </image>
            <staticText>
                <reportElement x="100" y="20" width="435" height="16" forecolor="#0F172A">
                    <printWhenExpression><![CDATA[$P{qrCodeStream} != null]]></printWhenExpression>
                </reportElement>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[Scan QR code to verify authenticity of this document]]></text>
            </staticText>
            <staticText>
                <reportElement x="100" y="38" width="435" height="14" forecolor="#64748B">
                    <printWhenExpression><![CDATA[$P{qrCodeStream} != null]]></printWhenExpression>
                </reportElement>
                <textElement><font size="7" fontName="SansSerif"/></textElement>
                <text><![CDATA[Use any QR scanner app. The code links to our secure document verification portal.]]></text>
            </staticText>
            <line><reportElement x="100" y="58" width="435" height="1" forecolor="#E2E8F0"/></line>
            <staticText>
                <reportElement x="100" y="64" width="435" height="46" forecolor="#94A3B8"/>
                <textElement><font size="7" isItalic="true" fontName="SansSerif"/></textElement>
                <text><![CDATA[This document is an official certificate generated by the ArabSoft Human Resources Management System. It is valid without a handwritten signature. Any alteration constitutes fraud. For inquiries, contact your HR department and quote the reference number above.]]></text>
            </staticText>
            <line><reportElement x="0" y="118" width="535" height="1" forecolor="#0F172A"/></line>
            <textField>
                <reportElement x="0" y="120" width="267" height="10" forecolor="#64748B"/>
                <textElement verticalAlignment="Middle"><font size="6" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA[$P{companyName} + " · Human Resources Management System"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="268" y="120" width="267" height="10" forecolor="#64748B"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="6" fontName="SansSerif"/></textElement>
                <textFieldExpression><![CDATA["Ref: " + $P{referenceNumber} + "  ·  Page 1 of 1"]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
