@startuml PasswordReset
title Password Reset Flow

skinparam sequenceArrowThickness 2
skinparam roundcorner 8
skinparam backgroundColor #FAFAFA
skinparam sequence {
  LifeLineBorderColor #1a6faf
  ActorBorderColor #1a6faf
  ParticipantBackgroundColor #EAF2FF
  ParticipantBorderColor #1a6faf
}

actor       "Client (Frontend)"       as C
participant "PasswordResetController" as PRC #EAF2FF
participant "PasswordResetService"    as PRS #EAF2FF
participant "PasswordResetKafkaProducer" as KP #FFF8E1
participant "Kafka Broker"            as KB  #FFF3CD
participant "PasswordResetKafkaConsumer" as KC #FFF8E1
participant "PasswordResetEmailService"  as ES #EAF2FF
participant "KeycloakAdminService"    as KAS #EAF2FF
participant "Keycloak Admin API"      as KA  #FFF3E0
database    "PostgreSQL"              as DB  #E8F5E9

== Step 1 : Request Reset Code ==

C   -> PRC : POST /public/auth/forgot-password\n{ email: "user@example.com" }
activate PRC
PRC -> PRS : initiatePasswordReset(email)
activate PRS

PRS -> DB  : SELECT person WHERE email = ?
activate DB
DB  --> PRS : Person (or empty)
deactivate DB

alt Email not found (silent — prevents enumeration)
    PRS --> PRC : (returns void, no error)
    PRC --> C   : 200 OK\n{ success:true,\n  message:"If an account exists..." }
else Email found
    PRS -> DB  : SELECT user WHERE person = ?
    activate DB
    DB  --> PRS : User
    deactivate DB

    PRS -> DB  : DELETE password_reset_tokens\nWHERE userId = ? (cleanup old tokens)
    activate DB
    DB  --> PRS : deleted
    deactivate DB

    note right of PRS
      generateUniqueResetToken():
      6-char alphanumeric (A-Z, 0-9)
      SecureRandom, expires in 15 min
    end note

    PRS -> DB  : INSERT password_reset_tokens\n(token, userId, email,\n createdAt, expiresAt, used=false)
    activate DB
    DB  --> PRS : saved
    deactivate DB

    PRS -> KP  : publishPasswordResetEvent\n(PasswordResetEvent)
    activate KP
    KP  -> KB  : send to topic "password-reset"\n{ email, firstName, lastName,\n  resetToken, expiryTime }
    KB  --> KP : ack
    deactivate KP

    PRS -> DB  : DELETE expired tokens\n(deleteByExpiresAtBefore)
    DB  --> PRS : cleaned

    PRS --> PRC : void
    PRC --> C   : 200 OK\n{ success:true,\n  message:"If an account exists..." }
end
deactivate PRS
deactivate PRC

== Async: Kafka Consumer sends email ==

KB  -> KC  : consume "password-reset" topic
activate KC
KC  -> ES  : sendPasswordResetEmail(PasswordResetEvent)
activate ES
ES  --> C  : 📧 Email with 6-char OTP code\n(HTML template, expires at HH:mm)
deactivate ES
deactivate KC

== Step 2 : Submit New Password ==

C   -> PRC : POST /public/auth/reset-password\n{ token: "ABC123", newPassword: "NewPass1" }
activate PRC
PRC -> PRS : resetPassword(token, newPassword)
activate PRS

PRS -> DB  : SELECT token WHERE token=? AND used=false
activate DB
DB  --> PRS : PasswordResetToken
deactivate DB

alt Token not found or already used
    PRS --> PRC : throws BadRequestException\n"Invalid or expired reset token"
    PRC --> C   : 400 Bad Request
else Token expired
    PRS -> DB  : DELETE token
    PRS --> PRC : throws BadRequestException\n"Reset token has expired"
    PRC --> C   : 400 Bad Request
else Token valid
    PRS -> DB  : SELECT user WHERE id = userId
    activate DB
    DB  --> PRS : User { keycloakId }
    deactivate DB

    note right of PRS
      validatePassword():
      • min 8 chars
      • at least 1 uppercase
      • at least 1 lowercase
      • at least 1 digit
    end note

    PRS -> KAS : resetUserPassword(keycloakId, newPassword)
    activate KAS
    KAS -> KA  : PUT /admin/realms/hr-realm/users/{id}/reset-password\n{ type:password, value:newPassword, temporary:false }
    activate KA
    KA  --> KAS : 204 No Content
    deactivate KA
    KAS --> PRS : true
    deactivate KAS

    PRS -> DB  : UPDATE token SET used=true
    activate DB
    DB  --> PRS : saved
    deactivate DB

    PRS --> PRC : void
    PRC --> C   : 200 OK\n{ success:true,\n  message:"Password reset successfully" }
end
deactivate PRS
deactivate PRC

@enduml
