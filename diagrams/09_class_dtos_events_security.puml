@startuml ClassDiagram_DTOs_Events
title DTOs · Events · Security Classes
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classFontStyle bold
skinparam classBackgroundColor #EAF2FF
skinparam classBorderColor #1a6faf
skinparam classArrowColor #555555
skinparam packageBackgroundColor #F8FBFF
skinparam packageBorderColor #1a6faf
skinparam roundcorner 8
skinparam shadowing false

' ══════════════════════════════════════════════════════════════════
' DTOs — AUTH
' ══════════════════════════════════════════════════════════════════
package "common.dto" #EAF2FF {

    class LoginRequest {
        - username : String
        - password : String
    }

    class LoginResponse {
        - success : boolean
        - message : String
        - accessToken : String
        - refreshToken : String
        - tokenType : String
        - expiresIn : int
        - username : String
        - email : String
        - roles : List<String>
        --
        + LoginResponse(errorMessage)
        + LoginResponse(token, refresh, type,\n  expires, username, email, roles)
    }

    class RegisterRequest {
        - username : String
        - password : String
        - firstName : String
        - lastName : String
        - email : String
        - phone : String
        - birthDate : LocalDate
        - address : String
        - maritalStatus : String
        - numberOfChildren : int
    }
}

' ══════════════════════════════════════════════════════════════════
' DTOs — AUTH (password reset)
' ══════════════════════════════════════════════════════════════════
package "modules.auth.dto" #EAF2FF {

    class ForgotPasswordRequest {
        - email : String
    }

    class ResetPasswordRequest {
        - token : String
        - newPassword : String
    }
}

' ══════════════════════════════════════════════════════════════════
' DTOs — HR
' ══════════════════════════════════════════════════════════════════
package "modules.hr.dto" #EAF2FF {

    class AssignRoleRequest {
        - userId : Long
        - role : String
    }

    class AssignRoleResponse {
        - success : boolean
        - message : String
        - userId : Long
        - username : String
        - oldRole : String
        - newRole : String
        - assignedBy : String
        - timestamp : LocalDateTime
        - eventPublished : boolean
        - note : String
        --
        + {static} builder() : AssignRoleResponseBuilder
    }

    class "AssignRoleResponse.AssignRoleResponseBuilder" as ARB {
        + success(v) : Builder
        + message(v) : Builder
        + userId(v) : Builder
        + username(v) : Builder
        + oldRole(v) : Builder
        + newRole(v) : Builder
        + assignedBy(v) : Builder
        + timestamp(v) : Builder
        + eventPublished(v) : Builder
        + note(v) : Builder
        + build() : AssignRoleResponse
    }

    AssignRoleResponse +-- ARB
}

