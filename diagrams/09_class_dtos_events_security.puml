        - hrDecision : ApprovalDecision
        - status : LeaveStatus
        - approvalDate : LocalDate
        - createdAt : LocalDateTime
    }
}

' ══════════════════════════════════════════════════════════════════
' EVENTS (Kafka messages)
' ══════════════════════════════════════════════════════════════════
package "common.event  <<Serializable>>" #FFF8E1 {

    class UserRoleAssignedEvent {
        - userId : Long
        - username : String
        - email : String
        - firstName : String
        - lastName : String
        - oldRole : String
        - newRole : String
        - assignedBy : String
        - timestamp : LocalDateTime
    }

    class PasswordResetEvent {
        - email : String
        - firstName : String
        - lastName : String
        - resetToken : String
        - timestamp : LocalDateTime
        - expiryTime : LocalDateTime
    }
}

' ══════════════════════════════════════════════════════════════════
' SECURITY
' ══════════════════════════════════════════════════════════════════
package "security" #FFE0B2 {

    class SecurityConfig {
        - keycloakRoleConverter : KeycloakRoleConverter
        - corsConfigurationSource : CorsConfigurationSource
        --
        + securityFilterChain(http) : SecurityFilterChain
        + jwtAuthenticationConverter() : JwtAuthenticationConverter
    }

    class KeycloakRoleConverter {
        - userRepository : UserRepository
        --
        + convert(jwt : Jwt) : Collection<GrantedAuthority>
        - extractRolesFromJwt(jwt) : Set<String>
        - fallbackToDatabase(jwt) : Set<String>
    }

    class CorsConfig {
        --
        + corsConfigurationSource() : CorsConfigurationSource
        ' Allowed origins: localhost:5173, 4173, 3000
        ' Allowed methods: GET POST PUT DELETE OPTIONS
    }
}

' ══════════════════════════════════════════════════════════════════
' KAFKA INFRASTRUCTURE
' ══════════════════════════════════════════════════════════════════
package "infrastructure.kafka" #FFF3CD {

    class KafkaEventProducer {
        - kafkaTemplate : KafkaTemplate
        - objectMapper : ObjectMapper
        --
        + publishUserRoleAssignedEvent(event) : void
    }

    class PasswordResetKafkaProducer {
        - kafkaTemplate : KafkaTemplate
        - objectMapper : ObjectMapper
        --
        + publishPasswordResetEvent(event) : void
    }

    class UserRoleEventConsumer {
        - emailNotificationService : EmailNotificationService
        - objectMapper : ObjectMapper
        --
        + handleUserRoleAssignedEvent(json) : void
    }

    class PasswordResetKafkaConsumer {
        - passwordResetEmailService : PasswordResetEmailService
        - objectMapper : ObjectMapper
        --
        + consumePasswordResetEvent(json) : void
    }
}

' ══════════════════════════════════════════════════════════════════
' RELATIONSHIPS
' ══════════════════════════════════════════════════════════════════

KafkaEventProducer        ..>  UserRoleAssignedEvent  : publishes
PasswordResetKafkaProducer ..> PasswordResetEvent     : publishes
UserRoleEventConsumer      ..>  UserRoleAssignedEvent  : consumes
PasswordResetKafkaConsumer ..>  PasswordResetEvent     : consumes

SecurityConfig             ..>  KeycloakRoleConverter

note top of UserRoleAssignedEvent
  Topic: "user-role-assigned"
  Triggered by: HRService.assignRoleToUser()
  Consumer sends welcome email via
  EmailNotificationService
end note

note top of PasswordResetEvent
  Topic: "password-reset"
  Triggered by: PasswordResetService.initiatePasswordReset()
  Consumer sends OTP email via
  PasswordResetEmailService
end note

note right of KeycloakRoleConverter
  1st: reads roles from JWT realm_access
  2nd: fallback → DB lookup by keycloakId/username
  3rd: defaults to NEW_USER
  Adds "ROLE_" prefix to each role
  (Spring Security convention)
end note

@enduml
