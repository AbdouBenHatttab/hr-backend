          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{diana_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"leaveType\": \"ANNUAL\",\n  \"startDate\": \"2026-05-01\",\n  \"endDate\": \"2026-05-05\",\n  \"numberOfDays\": 5,\n  \"reason\": \"Annual family vacation\"\n}" },
