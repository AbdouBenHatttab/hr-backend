    {
      "name": "6. LEAVE REQUEST — FULL APPROVAL CHAIN + PDF",
      "item": [
        {
          "name": "6.1 Diana — Submit Leave Request (leave_id auto-saved)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var res = pm.response.json();",
                "if (res.data && res.data.id) {",
                "    pm.collectionVariables.set('leave_id', res.data.id);",
                "    console.log('leave_id saved: ' + res.data.id);",
                "}"
